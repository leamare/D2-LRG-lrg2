  "items_stats_critical_desc": "рҹ“Ӯрҹ“Ҙрҹ”қ7пёҸвғЈ5пёҸвғЈ%рҹ”қрҹӣҚпёҸрҹҺҒвһ•вһ–вһ—рҹ“ү (рҹ‘ғвһЎпёҸвҸ°рҹӣҚпёҸ) рҹ‘ҶрҹҰёвҖҚвҷӮпёҸ. рҹ“Ҡ1пёҸвғЈрҹҹ°рҹҢ…вһ—вҸ°, вҡЎвҸ°рҹҹ°рҹ§®вҸ°рҹӣҚпёҸвҶ©пёҸрҹҺҒвһЎпёҸв¬ҮпёҸ5пёҸвғЈ0пёҸвғЈ%вһ—рҹҸҶ. рҹӘҹрҹҹ°вҶ”пёҸрҹҢ…вһ•вҡ пёҸвҸ°.",
  "builds_desc_1": "рҹ“ҚрҹҺҒрҹӣ пёҸрҹҸ—пёҸв¬…пёҸрҹҺҒрҹӣ пёҸрҹ“ҲрҹҢівһ•рҹҰёвҖҚвҷӮпёҸрҹҺҒрҹ“Ҡ (рҹ”Қрҹ‘Ҙрҹ‘Җвһ•рҹ“–). рҹҺҜрҹҹ°рҹ“°рҹ’ӘрҹҺҒрҹӣ пёҸвһЎпёҸрҹ§Ҙрҹ”ў,рҹ”Җ,рҹҺҜ,рҹӨ”рҹҺҒ,вҸ°в¬…пёҸрҹ’Ҝрҹ“Ҡ (рҹҷ…вҡҷпёҸвһ•рҹ“қ, рҹ“ң/рҹ’°). вқ”рҹӣ пёҸрҹҢівһЎпёҸрҹ‘ҶрҹҰёвҖҚвҷӮпёҸвһ•рҹҺӯвһЎпёҸрҹҷ…, рҹ“ҠвҡҷпёҸрҹ§Әрҹ•іпёҸ. рҹ“Қрҹӣ пёҸрҹҷ…рҹӨІрҹҺҜрҹӣ пёҸвһ•0пёҸвғЈрҹҺҒвҶ©пёҸрҹ‘Ҙрҹҷ…рҹ“қ (рҹ•’).",
  "builds_desc_2": "рҹҺӯрҹҹ°1пёҸвғЈрҹӣ пёҸ. вқ• рҹ‘Ҷрҹ”„рҹ”Қрҹ”ҖрҹӣЈпёҸрҹ”Қрҹ”ҖрҹҺҒрҹҺҜ (вқ”рҹҺ®вҡҷпёҸвңӢрҹҸҸ). рҹ’Һрҹӣ пёҸвһ•рҹҢҮвӯҗрҹӣЈпёҸв¬…пёҸрҹҺӯрҹ“ҲрҹҢі, рҹҢ…рҹҺҒ, рҹҳҗрҹҺҒ, вһ•рҹҢҮвһ•рҹ”қрҹ’ҘрҹҺҒв¬…пёҸрҹ“Ҡ, в¬…пёҸрҹӣҚпёҸрҹ“»вһ•вҸ°.",
  "builds_desc_3": "4пёҸвғЈрҹ§©рҹҺҒ: <b>рҹҳҗ</b>, <b>рҹ”„</b> (рҹ’ЎрҹҺЁ, рҹ”қрҹӣҚпёҸрҹ“»), <b>рҹ’Ә</b> (рҹҹў, рҹ”қвһ—рҹҸҶрҹ“Ҳ) вһ• <b>вҡЎ</b> (рҹ”ҙ, рҹ”қвһ–рҹ“үвһЎпёҸвҡЎвҸ°). рҹҺҒрҹ”ўрҹӣҚпёҸрҹ“»@вҶҳпёҸвҶҳпёҸ, вһ•3пёҸвғЈрҹ“Ҡ. рҹҘҮ3пёҸвғЈрҹ§©вһЎпёҸрҹ•ӣвҸ°, вһ—рҹҸҶрҹ“ҲрҹҶҡрҹҸҸрҹҷ…рҹӣҚпёҸвһ•вһ—вһ—рҹҸҶ. вҡЎрҹҺҒвһЎпёҸвҸ°рҹӘҹ (рҹҢ…вҸ°вһЎпёҸвҡЎвҸ°), вһ—рҹҸҶрҹ“Ҳвһ•рҹҢ…вҸ°вһ•вһ—рҹҸҶрҹ“ү. рҹ‘Ҷрҹ–ұпёҸвҶ—пёҸрҹҺҒ/#пёҸвғЈрҹ‘Җрҹ“–.",
  "builds_desc_4": "вһ—рҹҸҶрҹ“үвһЎпёҸрҹҺҒвһ—рҹҸҶвҶ”пёҸвҸұпёҸвҸ°. вһ–рҹ“үвһЎпёҸрҹҺҒв¬ҮпёҸрҹ‘ҚвҸұпёҸ. вҡЎвҸ°вһЎпёҸвҸ°вҶ©пёҸвһ—рҹҸҶв¬ҮпёҸрҹҰёвҖҚвҷӮпёҸвһ—.",
  "builds_desc_5": "рҹ“Ӯвһ—3пёҸвғЈрҹ”қрҹ“Ұ. рҹҘҮрҹ”қрҹ“ҰвһЎпёҸ<u>рҹӣ пёҸрҹ‘Җ</u>. рҹ“Ұрҹ“Ӯ: <b>рҹҢ…</b> (рҹҺҒрҹӣҚпёҸвҶ©пёҸрҹ’ҺрҹҺҒ, рҹ”„вҶ©пёҸрҹҺ®), <b>рҹ’Һ</b> (рҹҺҒвҡ пёҸрҹҰёвҖҚвҷӮпёҸ), <b>рҹҢҮ</b> (рҹҺҒвҶ©пёҸвҡ пёҸрҹҺҒрҹӣҚпёҸ), вһ• <b>рҹӨ”рҹҢ…</b> (рҹҺҒрҹҷ…рҹ“Ҙрҹҳҗрҹӣ пёҸ/рҹ”„вңӮпёҸ) вһ• <b>рҹӨ”</b> (вһ•рҹҢҮрҹҺҒ). рҹ‘Ҷрҹ‘Җрҹ“Ӯ: <b>рҹ”Җ</b> (рҹ’Ўрҹ”ҖрҹҺҒрҹҺҜ), <b>рҹ”ўрҹ”„</b> (2пёҸвғЈрҹҺҒрҹ”„рҹ”ўрҹӣ пёҸ) вһ• <b>рҹҳҗрҹҺҒ</b> (вқ”рҹ“Ҙ).",
  "builds_desc_6": "2пёҸвғЈрҹ”қрҹ“ҰвһЎпёҸ<u>рҹ•°пёҸрҹӣЈпёҸ</u>. рҹ‘ҒпёҸрҹ“әрҹ”ўрҹҢ…, рҹ’Һвһ•рҹӨ”рҹҺҒрҹ”„рҹӣҚпёҸ, вһ•рҹ’Ўрҹ”ўрҹ”„ (вһ—рҹҸҶрҹ“ҲвҸ°/рҹ”ўрҹӣҚпёҸ), рҹ”Җвһ•в¬ҮпёҸрҹҺҒрҹҺҜрҹ‘Җрҹӣ пёҸрҹ“Ҳ. рҹ’ЎрҹҺҒ (рҹ”қрҹ“ҰвҶ—пёҸрҹ’Ўрҹ”І) вһЎпёҸрҹ’Һрҹӣ пёҸ, рҹӨ”вһ•рҹҢ…рҹҺҒвңӮпёҸ. вҶ©пёҸрҹ•°пёҸрҹӣЈпёҸрҹ‘Ҷрҹ‘Җ<u>рҹҢҮ</u>рҹ“Ұ, рҹ”қрҹ”„рҹҢҮрҹӣЈпёҸ, вһ•вһ•рҹҢҮрҹҺҒрҹ”ўрҹ•ӣвҸ°рҹӣҚпёҸ. рҹ”ҡрҹ”қрҹ“Ұвһ•<u>рҹҳҗрҹҺҒ</u> (вқ”рҹ“Ҙ), вһ•рҹ“Ӣ<u>рҹ”қрҹ’ҘрҹҺҒ</u>рҹҷ…рҹ“Ҙрҹӣ пёҸ.",
  "builds_desc_7": "рҹӣ пёҸвҡҷпёҸрҹ“Ҡрҹ’Ә. рҹ”қрҹ“Ҡрҹ“Ҙрҹ”қрҹӣ пёҸрҹ‘Ҷ. рҹҳҗ, рҹҷ…рҹ”„рҹҺӯ/рҹҰёвҖҚвҷӮпёҸрҹҷ…рҹ”қрҹӣ пёҸ. рҹҺӯрҹҢірҹҸ—пёҸвқ”рҹҰёвҖҚвҷӮпёҸ5пёҸвғЈ%+рҹҸҸ@рҹҺӯ.",
  "desc_laning_1": "рҹӣЈпёҸвһ—рҹҸҶрҹ§®в¬…пёҸрҹ’°@рҹӣЈпёҸрҹ”ҡ. рҹ”қвҶ”пёҸвһЎпёҸрҹҸҶ/рҹ’”рҹӣЈпёҸ, в¬ҮпёҸвҶ”пёҸвһЎпёҸрҹ‘”. рҹҸҶрҹӣЈпёҸвһЎпёҸ1пёҸвғЈрҹ“Ҡ, рҹ‘”вһЎпёҸ0пёҸвғЈ.5пёҸвғЈ.",
  "desc_laning_2": "рҹӣЈпёҸрҹ“ҠрҹӨқв¬…пёҸрҹ’°рҹ”қрҹӘ“ (вқ”рҹӨқрҹӘ“рҹҸҶрҹӣЈпёҸ, рҹӨқвһЎпёҸрҹҸҶ).",
  "desc_laning_3": "рҹҸ…рҹӣЈпёҸрҹ“Ҡв¬…пёҸрҹӣЈпёҸвһ—рҹҸҶ, рҹҸҸ, вһ—вҶ”пёҸрҹӣЈпёҸрҹ“Ҳвһ•рҹҸҸвһ—рҹҸҶ. рҹҰёвҖҚвҷӮпёҸрҹӣЈпёҸрҹ“Ҡрҹ”қрҹҸ…вһЎпёҸрҹ”қрҹ‘ҠрҹҰёвҖҚвҷӮпёҸ (рҹҢ…). рҹӨ”в¬ҮпёҸвҶ”пёҸрҹ“Ҡ, в¬…пёҸрҹҷ…рҹ“–рҹ”Қрҹ”„рҹҷ…рҹ‘Ҡ@рҹӣЈпёҸ.",
  "desc_laning_4": "рҹ“ҚрҹӨ”1пёҸвғЈрҹ“Ҡрҹ”ҚрҹӣЈпёҸ, вҶ©пёҸрҹҷ…рҹ’Ә. рҹӨ”, в¬…пёҸрҹҺ®вһЎпёҸрҹ‘Қрҹ”„.",
  "desc_laning_5": "вҶ©пёҸв¬…пёҸрҹ’°, вһЎпёҸрҹҰёвҖҚвҷӮпёҸвһ•рҹҸ рҹ”Ә, вһ•рҹ’Җ. вһЎпёҸвқ”рҹҰёвҖҚвҷӮпёҸвһЎпёҸрҹҢІвһ•вҶ—пёҸрҹ’°, рҹҰёвҖҚвҷӮпёҸрҹҸҶрҹӣЈпёҸ (вқ”рҹҰёвҖҚвҷӮпёҸрҹҷ…рҹӣЈпёҸ).",
  "desc_laning_6": "рҹҰёвҖҚвҷӮпёҸрҹӣЈпёҸрҹҷ…1пёҸвғЈрҹҶҡ1пёҸвғЈрҹӣЈпёҸ. рҹӨқвһ•рҹ”ўрҹӘ“@рҹӣЈпёҸрҹ“Ҡ.",
  "desc_laning_7": "рҹҷ…\"рҹ’”рҹӣЈпёҸ1пёҸвғЈрҹҶҡ3пёҸвғЈ, рҹӨ”рҹҸҶрҹӣЈпёҸ\". вқ”рҹҰёвҖҚвҷӮпёҸрҹ’”рҹӣЈпёҸ, рҹӣЈпёҸрҹ’”, рҹҷ…рҹӨ”рҹ‘Ҷ. рҹӨ”, вһ—рҹҸҶв¬…пёҸрҹ’”/рҹ‘”/рҹҸҶрҹӣЈпёҸ, рҹ“әрҹ‘Ҷ, рҹҰёвҖҚвҷӮпёҸрҹ’Әвқ”рҹӣЈпёҸрҹ’”, рҹ“Ҡ. рҹ”„вҶ©пёҸ.",
  "desc_draft_explainer": "рҹ“Қрҹ“ӮвһЎпёҸрҹ“ҠвһЎпёҸрҹ”ҖвңҸпёҸрҹӘң. рҹҺӯрҹӘңрҹҸҒрҹ”„рҹҢҗвқҢвң…рҹ”„рҹҸҒ (рҹҶ•вқҢрҹӘңрҹҺ¬).",
  "desc_draft_targeted_bans_estimate_explainer": "рҹӨ“вңҸпёҸрҹ“ӮвһЎпёҸрҹ”„рҹҰёвҖҚвҷӮпёҸрҹ‘ҶрҹӨ“вң…@рҹҺҜвңҸпёҸрҹӘң. вһ•рҹ“Ҙрҹ“ҠвқҢрҹ”ўвһЎпёҸрҹ”„вқҢрҹҰёвҖҚвҷӮпёҸрҹҺҜвқҢрҹҺҜрҹ‘ҶрҹӨ“. рҹ“Ҡв¬…пёҸвңҸпёҸрҹҶҡрҹ‘ЁвҖҚрҹ‘ЁвҖҚрҹ‘ҰвҖҚрҹ‘Ұрҹ‘ҘрҹҺ®рҹҺӯрҹҰёвҖҚвҷӮпёҸвһ•рҹҺӯ. вқ”рҹҰёвҖҚвҷӮпёҸрҹҷ…вң…вҶ©пёҸрҹҺӘвңҸпёҸрҹӘңвҡҷпёҸрҹ“ҠрҹҺҜвқҢ. вқ”рҹ”ўрҹӨ“рҹ”ҚвқҢрҹ“Ӣв¬…пёҸ{рҹҰёвҖҚвҷӮпёҸ/рҹҺӯ/рҹӘң}вң…вҶ”пёҸ.",
